direction: down

title: {
  label: Data Flow & Storage
  near: top-center
  shape: text
  style: { font-size: 28; bold: true; font-color: "#1a1a2e" }
}

# ── Input Sources ─────────────────────────────────

inputs: {
  label: "Input Sources"
  style: { fill: "#e3f2fd"; stroke: "#1976d2"; border-radius: 12; bold: true; font-size: 16 }

  path: {
    label: "Project Path"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }

  github_url: {
    label: "GitHub URL"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }

  vault_idea: {
    label: "Vault Idea"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }

  raw_prompt: {
    label: "Raw Prompt"
    shape: rectangle
    style: { fill: "#bbdefb"; stroke: "#1976d2"; border-radius: 6; font-size: 14 }
  }
}

# ── Configuration ─────────────────────────────────

config: {
  label: "Configuration Layer"
  style: { fill: "#f0f4ff"; stroke: "#5c6bc0"; border-radius: 12; bold: true; font-size: 16 }

  factory_md: {
    label: |md
      **factory.md**
      goal, scope, guards,
      eval command, threshold,
      smoke test, target branch,
      project eval, eval weights,
      hypothesis budget
    |
    shape: document
    style: { fill: "#e8eaf6"; stroke: "#5c6bc0"; border-radius: 6; font-size: 13 }
    width: 240
  }

  config_json: {
    label: ".factory/config.json\n(parsed config)"
    shape: cylinder
    style: { fill: "#e8eaf6"; stroke: "#5c6bc0"; font-size: 13 }
  }

  eval_profile: {
    label: ".factory/eval_profile.json\n(discovered dimensions)"
    shape: cylinder
    style: { fill: "#e8eaf6"; stroke: "#5c6bc0"; font-size: 13 }
  }

  factory_md -> config_json: "factory init --reparse" {
    style: { font-size: 12 }
  }
}

# ── Strategy Layer ────────────────────────────────

strategy: {
  label: "Strategy Layer"
  style: { fill: "#e8f5e9"; stroke: "#2e7d32"; border-radius: 12; bold: true; font-size: 16 }

  backlog: {
    label: "backlog.md\nwork queue\n(single source of truth)"
    shape: document
    style: { fill: "#a5d6a7"; stroke: "#2e7d32"; border-radius: 6; font-size: 13 }
    width: 220
  }

  observations: {
    label: "observations.md\nlocal analysis +\ncross-project insights"
    shape: document
    style: { fill: "#c8e6c9"; stroke: "#43a047"; border-radius: 6; font-size: 13 }
    width: 220
  }

  research: {
    label: "research.md\nweb research +\nvault synthesis"
    shape: document
    style: { fill: "#c8e6c9"; stroke: "#43a047"; border-radius: 6; font-size: 13 }
    width: 200
  }

  current: {
    label: "current.md\nhypotheses +\npriorities"
    shape: document
    style: { fill: "#c8e6c9"; stroke: "#43a047"; border-radius: 6; font-size: 13 }
    width: 180
  }

  backlog -> observations: "items feed study"
  observations -> current
  research -> current
}

# ── Experiment Artifacts ──────────────────────────

experiments: {
  label: "Experiment Artifacts"
  style: { fill: "#fff3e0"; stroke: "#ef6c00"; border-radius: 12; bold: true; font-size: 16 }

  results_tsv: {
    label: "results.tsv\nappend-only history"
    shape: cylinder
    style: { fill: "#ffe0b2"; stroke: "#ef6c00"; font-size: 13 }
  }

  per_exp: {
    label: |md
      **experiments/NNN/**
      - hypothesis.md
      - eval_before.json
      - eval_after.json
      - changes.diff
      - verdict.json
    |
    shape: page
    style: { fill: "#fff8e1"; stroke: "#ff8f00"; border-radius: 6; font-size: 12 }
    width: 200
  }

  reviews: {
    label: |md
      **reviews/**
      - role-latest.md
      - ceo-verdict-role.md
      - archivist-checkpoints.md
    |
    shape: page
    style: { fill: "#fff8e1"; stroke: "#ff8f00"; border-radius: 6; font-size: 12 }
    width: 220
  }

  events: {
    label: "events.jsonl\nagent activity log"
    shape: cylinder
    style: { fill: "#ffe0b2"; stroke: "#ef6c00"; font-size: 13 }
  }
}

# ── External Systems ──────────────────────────────

external: {
  label: "External Systems"
  style: { fill: "#fce4ec"; stroke: "#c62828"; border-radius: 12; bold: true; font-size: 16 }

  github: {
    label: "GitHub\nIssues, PRs, Reviews"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
    width: 200
  }

  vault: {
    label: "Obsidian Vault\nProject dashboards,\nExperiment notes,\nCEO decision patterns"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
    width: 220
  }

  telegram: {
    label: "Telegram\nDigest notifications"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
  }

  dashboard: {
    label: "Live Dashboard\n:8420 SSE stream"
    shape: rectangle
    style: { fill: "#ffcdd2"; stroke: "#e53935"; border-radius: 6; font-size: 13 }
  }
}

# ── ACE Self-Improvement ─────────────────────────

ace: {
  label: "ACE Self-Improvement"
  style: { fill: "#f3e5f5"; stroke: "#7b1fa2"; border-radius: 12; bold: true; font-size: 16 }

  playbooks: {
    label: "agents/playbooks/*.md\nDO/DON'T rules with\nhelpful/harmful counters"
    shape: document
    style: { fill: "#e1bee7"; stroke: "#8e24aa"; border-radius: 6; font-size: 13 }
    width: 240
  }

  reflect: {
    label: "Reflect\nanalyze experiments"
    shape: rectangle
    style: { fill: "#e1bee7"; stroke: "#8e24aa"; border-radius: 6; font-size: 13 }
  }

  curate: {
    label: "Curate\nmerge + prune"
    shape: rectangle
    style: { fill: "#e1bee7"; stroke: "#8e24aa"; border-radius: 6; font-size: 13 }
  }

  reflect -> curate -> playbooks
}

# ── Flow connections ──────────────────────────────

inputs -> config: "resolve input" {
  style: { font-size: 13 }
}
config -> strategy: "goals & constraints" {
  style: { font-size: 13 }
}
strategy -> experiments: "hypotheses drive experiments" {
  style: { font-size: 13 }
}
experiments -> external: "issues, PRs, vault writes, notifications" {
  style: { font-size: 13 }
}
experiments -> ace: "experiment outcomes feed learning" {
  style: { font-size: 13 }
}
ace -> strategy: "evolved playbooks improve agents" {
  style: { font-size: 13; stroke-dash: 5 }
}

# ── Research Mode Artifacts ──────────────────────

research_config: {
  label: "Research Configuration"
  style: { fill: "#e0f7fa"; stroke: "#00838f"; border-radius: 12; bold: true; font-size: 16 }

  research_target: {
    label: |md
      **research_target**
      objective, metric, target,
      run_command, result_path,
      result_parser, timeout
    |
    shape: document
    style: { fill: "#b2ebf2"; stroke: "#00838f"; border-radius: 6; font-size: 13 }
    width: 220
  }

  mutable_surfaces: {
    label: "mutable_surfaces\nfiles Builder can modify"
    shape: document
    style: { fill: "#b2ebf2"; stroke: "#00838f"; border-radius: 6; font-size: 13 }
    width: 220
  }

  fixed_surfaces: {
    label: "fixed_surfaces\nground truth (locked)\nfingerprinted for leakage"
    shape: document
    style: { fill: "#ffcdd2"; stroke: "#c62828"; border-radius: 6; font-size: 13 }
    width: 220
  }
}

research_artifacts: {
  label: "Research Run Artifacts"
  style: { fill: "#e0f7fa"; stroke: "#00838f"; border-radius: 12; bold: true; font-size: 16 }

  runs: {
    label: |md
      **research/runs/<cycle_id>/**
      - stdout.log
      - stderr.log
      - summary.json
      - failure_analysis.md
    |
    shape: page
    style: { fill: "#b2ebf2"; stroke: "#00838f"; border-radius: 6; font-size: 12 }
    width: 220
  }

  leakage: {
    label: "Leakage Guard\ntoken overlap, negation\nhints, specific values"
    shape: hexagon
    style: { fill: "#ffcdd2"; stroke: "#c62828"; font-size: 13 }
  }
}

config -> research_config: "research target config" {
  style: { font-size: 13; stroke: "#00838f" }
}
research_config -> strategy: "surface constraints" {
  style: { font-size: 13; stroke: "#00838f" }
}
research_config -> research_artifacts: "run_command execution" {
  style: { font-size: 13; stroke: "#00838f" }
}
research_artifacts -> strategy: "failure analysis informs hypotheses" {
  style: { font-size: 13; stroke: "#00838f"; stroke-dash: 5 }
}
research_config -> research_artifacts.leakage: "fixed surface fingerprints" {
  style: { font-size: 12; stroke: "#c62828" }
}
