<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Experiment {{ exp_id }} — {{ project_name }}</title>
  <style>
{{ pico_css }}
  </style>
  <style>
    .badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 0.25rem;
      font-weight: 700;
      font-size: 0.875rem;
      text-transform: uppercase;
    }
    .badge-keep { background: #2e7d32; color: #fff; }
    .badge-revert { background: #c62828; color: #fff; }
    .badge-pending { background: #757575; color: #fff; }
    .delta-positive { color: #2e7d32; font-weight: 600; }
    .delta-negative { color: #c62828; font-weight: 600; }
    .delta-zero { color: #757575; }
    pre.diff {
      overflow-x: auto;
      font-size: 0.8125rem;
      line-height: 1.4;
    }
  </style>
</head>
<body>
  <header>
    <h1>Experiment #{{ exp_id }}</h1>
    <p>
      <strong>{{ project_name }}</strong>
      {% if verdict %}
      &mdash;
      {% if verdict.lower() == "keep" %}
      <span class="badge badge-keep">KEEP</span>
      {% elif verdict.lower() == "revert" %}
      <span class="badge badge-revert">REVERT</span>
      {% else %}
      <span class="badge badge-pending">{{ verdict | upper }}</span>
      {% endif %}
      {% else %}
      &mdash; <span class="badge badge-pending">PENDING</span>
      {% endif %}
    </p>
    {% if date %}<p><small>{{ date }}</small></p>{% endif %}
  </header>

  <main>
    <section>
      <h2>Hypothesis</h2>
      {% if hypothesis %}
      {{ hypothesis }}
      {% else %}
      <p><em>No hypothesis recorded.</em></p>
      {% endif %}
    </section>

    {% if eval_results %}
    <section>
      <h2>Eval Results</h2>
      <table>
        <thead>
          <tr>
            <th scope="col">Dimension</th>
            <th scope="col">Before</th>
            <th scope="col">After</th>
            <th scope="col">Delta</th>
          </tr>
        </thead>
        <tbody>
          {% for row in eval_results %}
          <tr>
            <td>{{ row.dimension }}</td>
            <td>{{ "%.3f" | format(row.before) }}</td>
            <td>{{ "%.3f" | format(row.after) }}</td>
            <td>
              {% set delta = row.after - row.before %}
              <span class="{% if delta > 0 %}delta-positive{% elif delta < 0 %}delta-negative{% else %}delta-zero{% endif %}">
                {{ "%+.3f" | format(delta) }}
              </span>
            </td>
          </tr>
          {% endfor %}
        </tbody>
        {% if composite_before is not none and composite_after is not none %}
        <tfoot>
          <tr>
            <th scope="row">Composite</th>
            <td><strong>{{ "%.3f" | format(composite_before) }}</strong></td>
            <td><strong>{{ "%.3f" | format(composite_after) }}</strong></td>
            <td>
              {% set cdelta = composite_after - composite_before %}
              <strong>
                <span class="{% if cdelta > 0 %}delta-positive{% elif cdelta < 0 %}delta-negative{% else %}delta-zero{% endif %}">
                  {{ "%+.3f" | format(cdelta) }}
                </span>
              </strong>
            </td>
          </tr>
        </tfoot>
        {% endif %}
      </table>
    </section>
    {% endif %}

    {% if changes_summary %}
    <section>
      <h2>Changes</h2>
      <article>
        {{ changes_summary }}
      </article>
    </section>
    {% endif %}

    {% if verdict_rationale %}
    <section>
      <h2>Verdict Rationale</h2>
      <article>
        {{ verdict_rationale }}
      </article>
    </section>
    {% endif %}
  </main>

  <footer>
    <p><small>Generated by Factory Reporter</small></p>
  </footer>
</body>
</html>
